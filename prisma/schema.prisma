// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  MANAGER
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
}

enum MovementType {
  IN
  OUT
  ADJUST
}

enum SalesOrderStatus {
  RECEIVED
  SHIPPED
  CANCELED
}

enum PurchaseOrderStatus {
  REQUESTED
  RECEIVED
  CANCELED
}

model User {
  id        Int      @id @default(autoincrement())
  password  String
  username  String   @unique
  role      Role
  createdAt DateTime @default(now())
  isDelete  Boolean  @default(false)
}

model Product {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  name         String
  price        Int
  safetyStock  Int
  currentStock Int
  createdAt    DateTime @default(now())
  isSale       Boolean  @default(true)

  stockMovements StockMovement[]
  purchaseOrders PurchaseOrders[]
  SalesOrders    SalesOrders[]
}

model Partner {
  id        Int         @id @default(autoincrement())
  name      String
  type      PartnerType
  phone     String
  email     String?
  createdAt DateTime    @default(now())
  isActive  Boolean     @default(true)

  purchaseOrders PurchaseOrders[]
  SalesOrders    SalesOrders[]
}

model StockMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  quantity  Int
  type      MovementType
  memo      String?
  createdAt DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model PurchaseOrders {
  id        Int                 @id @default(autoincrement())
  partnerId Int
  productId Int
  quantity  Int
  status    PurchaseOrderStatus @default(REQUESTED)
  createdAt DateTime            @default(now())

  partner Partner @relation(fields: [partnerId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model SalesOrders {
  id        Int              @id @default(autoincrement())
  partnerId Int
  productId Int
  quantity  Int
  status    SalesOrderStatus @default(RECEIVED)
  createdAt DateTime         @default(now())

  partner Partner @relation(fields: [partnerId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}
