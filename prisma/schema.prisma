// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  MANAGER
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
}

enum MovementType {
  IN
  OUT
  ADJUST
}

enum SaleOrderStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  CANCELED
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  COMPLETED
  CANCELED
}

model User {
  id        Int      @id @default(autoincrement())
  password  String
  username  String   @unique
  role      Role
  createdAt DateTime @default(now())
  isDelete  Boolean  @default(false)
}

model Product {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  name         String
  price        Int
  safetyStock  Int
  currentStock Int
  createdAt    DateTime @default(now())
  isSale       Boolean  @default(true)

  purchaseOrderProducts PurchaseOrderProduct[]
  saleOrderProducts     SaleOrderProduct[]
  stockMovements        StockMovement[]
}

model Partner {
  id        Int         @id @default(autoincrement())
  name      String
  type      PartnerType
  phone     String
  email     String?
  createdAt DateTime    @default(now())
  isActive  Boolean     @default(true)

  purchaseOrders PurchaseOrder[]
  saleOrders     SaleOrder[]
}

model StockMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  quantity  Int
  type      MovementType
  memo      String?
  createdAt DateTime     @default(now())
  refId     Int?

  product Product @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id        Int                 @id @default(autoincrement())
  partnerId Int
  status    PurchaseOrderStatus @default(DRAFT)
  createdAt DateTime            @default(now())

  partner Partner @relation(fields: [partnerId], references: [id])

  purchaseOrderProducts PurchaseOrderProduct[]
  purchaseOrderStatuses PurchaseOrderStatusLog[]
}

model PurchaseOrderProduct {
  purchaseId Int
  productId  Int
  quantity   Int
  unitPrice  Int

  purchaseOrder PurchaseOrder @relation(fields: [purchaseId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@id([purchaseId, productId])
}

model PurchaseOrderStatusLog {
  id         Int                 @id @default(autoincrement())
  purchaseId Int
  status     PurchaseOrderStatus
  createdAt  DateTime            @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseId], references: [id])
}

model SaleOrder {
  id        Int             @id @default(autoincrement())
  partnerId Int
  status    SaleOrderStatus @default(RECEIVED)
  createdAt DateTime        @default(now())

  partner           Partner              @relation(fields: [partnerId], references: [id])
  saleOrderProducts SaleOrderProduct[]
  saleOrderStatuses SaleOrderStatusLog[]
}

model SaleOrderProduct {
  saleId    Int
  productId Int
  quantity  Int
  unitPrice Int

  saleOrder SaleOrder @relation(fields: [saleId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@id([saleId, productId])
}

model SaleOrderStatusLog {
  id        Int             @id @default(autoincrement())
  saleId    Int
  status    SaleOrderStatus
  createdAt DateTime        @default(now())

  saleOrder SaleOrder @relation(fields: [saleId], references: [id])
}
