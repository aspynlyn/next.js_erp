// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  MANAGER
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
}

enum MovementType {
  IN
  OUT
  ADJUST
}

model User {
  uId        Int      @id @default(autoincrement())
  uPassword  String
  uUsername  String   @unique
  uRole      Role
  uCreatedAt DateTime @default(now())
  uIsDelete  Boolean  @default(false)
}

model Product {
  pdId           Int             @id @default(autoincrement())
  pdCode         String          @unique
  pdName         String
  pdPrice        Int
  pdSafetyStock  Int
  pdCurrentStock Int
  pdCreatedAt    DateTime        @default(now())
  pdIsSale       Boolean         @default(true)
  stockMovements StockMovement[]
}

model Partner {
  ptId        Int         @id @default(autoincrement())
  ptName      String
  ptType      PartnerType
  ptPhone     String
  ptEmail     String?
  ptCreatedAt DateTime    @default(now())
  ptIsActive  Boolean     @default(true)
}

model StockMovement {
  smId        Int          @id @default(autoincrement())
  smProductId Int
  smQuantity  Int
  smType      MovementType
  smMemo      String?
  smCreatedAt DateTime     @default(now())

  product Product @relation(fields: [smProductId], references: [pdId])
}
